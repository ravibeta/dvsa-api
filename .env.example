# Environment Configuration Template
# Copy this to .env and update with your actual values

# Django Settings
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dvsa_db
# For development: sqlite:///db.sqlite3

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Azure control-plane (ARM) — required only to provision GLOBAL resources.
# Leave blank to run core.azure in dry-run mode (no network, no credentials).
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-dvsa
AZURE_LOCATION=eastus
# auto | sdk | terraform | dryrun
AZURE_PROVISIONER=auto
# Path to the Terraform module (used when AZURE_PROVISIONER=terraform)
AZURE_TERRAFORM_DIR=solution-accelerator

# Azure Blob Storage
AZURE_ACCOUNT_NAME=your-account-name
AZURE_ACCOUNT_KEY=your-account-key
AZURE_CONTAINER_NAME=videos
AZURE_STORAGE_CONNECTION_STRING=
# Dedicated drone-video account + its two containers
AZURE_STORAGE_ACCOUNT=sadronevideo
AZURE_STORAGE_INPUT_CONTAINER=input
AZURE_STORAGE_OUTPUT_CONTAINER=output

# Azure AI Vision
AZURE_AI_VISION_API_KEY=
AZURE_AI_VISION_REGION=eastus
AZURE_AI_VISION_ENDPOINT=

# Azure AI Search
AZURE_SEARCH_SERVICE_NAME=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=dvsa-index
AZURE_SEARCH_SKU=standard
AZURE_SEARCH_VECTOR_DIMENSIONS=1536
# index | filter
AZURE_SESSION_ISOLATION=index

# Azure OpenAI / AI Foundry (models, agents, deployments)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ACCOUNT=dvsa-foundry
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_GPT_MODEL=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Azure AI Foundry project (agents/threads) + agent role names
AZURE_PROJECT_ENDPOINT=
AZURE_PROJECT_API_KEY=
AZURE_AGENT_MODEL=gpt-4o-mini
AZURE_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_FN_AGENT_NAME=fn-agent-in-a-team
AZURE_CHAT_AGENT_NAME=chat-agent-in-a-team
AZURE_SEARCH_AGENT_NAME=search-agent-in-a-team
AZURE_TOOL_AGENT_NAME=tool-agent-in-a-team
AZURE_SEARCH_CONNECTION_ID=
AZURE_SEARCH_RESOURCE_ID=
AZURE_SEARCH_SUBSCRIPTION=
AZURE_SEARCH_RESOURCE_GROUP=
AZURE_SEARCH_LOCATION=eastus

# API versions for Vision / Search / embedding REST calls
AZURE_VISION_API_VERSION=2024-02-01
AZURE_SEARCH_API_VERSION=2025-08-01-preview
AZURE_VISION_MODEL_VERSION=2023-04-15

# Azure Video Indexer
AZURE_VIDEO_INDEXER_URL=https://api.videoindexer.ai
AZURE_VIDEO_INDEXER_REGION=eastus
AZURE_VIDEO_INDEXER_ACCOUNT=
AZURE_VIDEO_INDEXER_API_KEY=
AZURE_VIDEO_INDEXER_ACCESS_TOKEN=

# Perplexity (image geolocation + multimodal retrieval fallback)
PERPLEXITY_CHAT_API_KEY=
PERPLEXITY_CHAT_API_URL=https://api.perplexity.ai/chat/completions
PERPLEXITY_GEO_API_KEY=
PERPLEXITY_GEO_API_URL=https://api.perplexity.ai/v1/image/geolocation

# Sample object/scene image URIs used by object-in-scene search
SAMPLE_OBJECT_URI=
SAMPLE_SCENE_URI=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dvsa.log

# API
API_PAGINATION_SIZE=50
API_MAX_PAGE_SIZE=500
API_TIMEOUT_SECONDS=30

# Video Processing
MAX_VIDEO_UPLOAD_SIZE=1073741824  # 1GB in bytes
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv
VIDEO_PROCESSING_TIMEOUT=3600  # 1 hour

# Geospatial
GEOSPATIAL_ENABLED=True
GPS_PRECISION_METERS=5

# Monitoring & Analytics
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
